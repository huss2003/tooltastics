---
import { SITE } from '@config/site'
import type { Locale } from '@config/constants'
import en from '@lib/i18n/translations/en.json'

export interface Props {
  locale?: string
}

const { locale = 'en' } = Astro.props
const loc = locale as Locale
const t = (key: string): string => en[key as keyof typeof en] ?? key
const year = new Date().getFullYear()
---

<footer class="mt-auto border-t bg-surface-100 dark:bg-surface-900">
  <div class="mx-auto flex max-w-7xl flex-col items-center gap-4 px-4 py-8 sm:flex-row sm:justify-between sm:px-6 lg:px-8">
    <p class="text-sm text-surface-500">
      {year} {SITE.name}. All rights reserved.
    </p>

    <div class="flex items-center gap-4 text-sm text-surface-500">
      <a href={`/${loc}/privacy-policy`} class="hover:text-surface-700 dark:hover:text-surface-300">{t('footer.privacy')}</a>
      <a href={`/${loc}/terms-and-conditions`} class="hover:text-surface-700 dark:hover:text-surface-300">{t('footer.terms')}</a>
      <span class="text-surface-300 dark:text-surface-600">|</span>
      <span>{SITE.name} v1.0.0</span>
    </div>
  </div>
</footer>
