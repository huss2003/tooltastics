<div class="flex flex-1 flex-col {Astro.props.class ?? ''}">
  <div
    class="relative flex-1 min-h-[300px] lg:min-h-[400px] rounded-xl border border-surface-200 dark:border-surface-700 bg-white dark:bg-surface-900 overflow-hidden"
    data-canvas-container
    role="img"
    aria-label="L-square tool — measure right angles on your screen"
  >
    <canvas
      id="l-square-canvas"
      class="block w-full h-full"
      role="application"
      aria-roledescription="l-square"
      aria-label="Interactive L-square. Click to place a measurement point. Use arrow keys to adjust."
      tabindex="0"
    />
  </div>

  <div
    class="mt-3 flex items-center justify-center gap-2 rounded-lg bg-surface-100 dark:bg-surface-800 px-4 py-3 text-center text-sm text-surface-500 dark:text-surface-400 min-h-[44px]"
    data-readout
    aria-live="polite"
    aria-atomic="true"
  >
    Click on the L-square to measure
  </div>
</div>

<style>
  #l-square-canvas {
    touch-action: none;
  }
</style>

<script>
  import { initLSquare } from './l-square-init'
  initLSquare()
</script>
