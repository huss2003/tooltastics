  path: '/cm-ruler-online',
  ogType: 'article',
  schema: [
    article(
      'CM Ruler Online — Measure in Centimeters on Your Screen',
      'Free online cm ruler. Measure any object in centimeters on your screen with calibrated accuracy. Perfect for metric measurements and international standards.',
      {
        locale,
        canonical,
        title: 'CM Ruler Online — Measure in Centimeters on Your Screen',
        description:
          'Free online cm ruler. Measure any object in centimeters on your screen with calibrated accuracy. Perfect for metric measurements and international standards.',
        datePublished: '2025-03-05',
        dateModified: '2025-06-01',
      },
    ),
    breadcrumbList([
      { name: 'RulerKit', url: `${SITE.url}/${locale}/` },
      { name: 'Guides', url: `${SITE.url}/${locale}/guides` },
      { name: 'CM Ruler Online', url: canonical },
    ]),
  ],
  breadcrumbs: [
    { name: 'RulerKit', url: `${SITE.url}/${locale}/` },
    { name: 'Guides', url: `${SITE.url}/${locale}/guides` },
    { name: 'CM Ruler Online', url: canonical },
  ],
  publishedTime: '2025-03-05',
  modifiedTime: '2025-06-01',
