---
import BaseLayout from './BaseLayout.astro'
import type { Metadata } from '@lib/seo/metadata'

export interface Props {
  metadata: Metadata
  title: string
}

const { metadata, title } = Astro.props
---

<BaseLayout metadata={metadata}>
  <div slot="head">
    <slot name="head" />
  </div>

  <div class="grid gap-6 lg:grid-cols-[280px,1fr]">
    <aside class="order-2 lg:order-1 lg:h-[calc(100dvh-8rem)] lg:overflow-y-auto">
      <slot name="sidebar" />
    </aside>

    <section class="order-1 lg:order-2 min-w-0 overflow-x-auto" aria-label={title}>
      <slot name="canvas" />
    </section>
  </div>

  <slot />
</BaseLayout>
